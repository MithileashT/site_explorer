# LLM — defaults to Ollama; set OPENAI_API_KEY + OPENAI_MODEL to add OpenAI option
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5-coder
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# File storage
BAG_UPLOAD_DIR=data/bags
SITES_ROOT=data/sites

# Vector DB
FAISS_PATH=data/faiss.index
META_PATH=data/metadata.json

# Site data sync (set SITE_SYNC_ENABLED=true and REPO_URL to enable)
SITE_SYNC_ENABLED=false
REPO_URL=

# External integrations (all optional)
SLACK_BOT_TOKEN=
GRAFANA_API_KEY=
GITHUB_TOKEN=

# CORS — comma-separated origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
